# Docker Compose
POSTGRES_USER=ehub
POSTGRES_PASSWORD=ehub
POSTGRES_DB=ehub
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@ehub.local
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

REDIS_PORT=6379

# eHub.Api — ASP.NET Core environment variables (__ = nested section)
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=ehub;Username=ehub;Password=ehub
ConnectionStrings__Redis=localhost:6379
Database__CommandTimeoutSeconds=30
Redis__InstanceName=ehub:
Redis__DefaultDatabase=0
